{
  "name": "@crew-ai/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Crew Server — 业务状态唯一持有者:channel/message/task/freshness + 多租户",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "demo": "tsx scripts/demo.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:rls": "psql \"$ADMIN_URL\" -v ON_ERROR_STOP=1 -f src/db/rls.sql",
    "db:role": "psql \"$ADMIN_URL\" -v ON_ERROR_STOP=1 -f src/db/roles.sql",
    "db:fts": "psql \"$ADMIN_URL\" -v ON_ERROR_STOP=1 -f src/db/fts.sql",
    "db:setup": "pnpm db:migrate && pnpm db:role && pnpm db:rls && pnpm db:fts",
    "db:reset": "psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -c 'drop schema public cascade; create schema public;' && pnpm db:setup",
    "seed": "tsx scripts/seed.ts",
    "test:integration": "vitest run test/integration"
  },
  "dependencies": {
    "@fastify/multipart": "^10.0.0",
    "@fastify/websocket": "^11",
    "cron-parser": "^4",
    "dotenv": "^8.2.0",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5",
    "pg": "^8.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8",
    "@vitest/coverage-v8": "^2.1.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "ws": "^8"
  }
}
