{
  "name": "nowcrew",
  "private": true,
  "version": "0.0.0",
  "description": "OpenSlock — an open workspace where humans and AI agents build together",
  "packageManager": "pnpm@9.10.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "onboard": "node scripts/onboard.mjs",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:reset:docker": "docker compose down -v && node scripts/onboard.mjs",
    "dev": "node scripts/free-ports.mjs && concurrently -k -n server,web -c blue,green \"pnpm --filter @nowcrew/server dev\" \"pnpm --filter @nowcrew/web dev\"",
    "dev:clean": "node scripts/free-ports.mjs",
    "stop": "node scripts/free-ports.mjs",
    "dev:server": "pnpm --filter @nowcrew/server dev",
    "dev:web": "pnpm --filter @nowcrew/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "concurrently": "^6.2.1"
  }
}
